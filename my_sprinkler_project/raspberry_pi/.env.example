# ── Raspberry Pi Environment Configuration ─────────────────────────────────
# Copy to .env and fill in your values.

# ── Gemini API ───────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# ── MQTT Broker ──────────────────────────────────────────────────────────────
MQTT_BROKER_IP=192.168.1.100
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=agriwatch-pi

# ── Polling Intervals (seconds) ───────────────────────────────────────────────
SENSOR_POLL_INTERVAL=5
INFERENCE_INTERVAL=30
DISPLAY_UPDATE_INTERVAL=10

# ── Camera ────────────────────────────────────────────────────────────────────
CAPTURE_DIR=/home/pi/captures
STREAM_PORT=8080
CAPTURE_WIDTH=1280
CAPTURE_HEIGHT=960
STREAM_WIDTH=640
STREAM_HEIGHT=480

# ── Sensor Hardware ───────────────────────────────────────────────────────────
ADS1115_I2C_BUS=1
DHT_GPIO_PIN=4
NPK_SERIAL_PORT=/dev/ttyUSB0
NPK_BAUD_RATE=4800
BH1750_I2C_BUS=1

# ── pH Probe Calibration ─────────────────────────────────────────────────────
# Measure voltage at pH 4.0 and pH 7.0 buffer solutions, then adjust these.
PH_SLOPE=3.5
PH_OFFSET=0.0

# ── Moisture Calibration ─────────────────────────────────────────────────────
# DRY_RAW  = ADS1115 reading with sensor in dry air
# WET_RAW  = ADS1115 reading with sensor fully submerged
MOISTURE_DRY_RAW=26000
MOISTURE_WET_RAW=13000

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_DIR=/home/pi/logs
