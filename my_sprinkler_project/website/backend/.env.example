# ── Backend Environment Configuration ────────────────────────────────────────
# Copy this to .env and fill in your values

# MQTT Broker (Mosquitto running on Pi or a separate server)
MQTT_BROKER_IP=192.168.1.100
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=agriwatch-backend

# Database (SQLite default; switch to PostgreSQL for production)
DATABASE_URL=sqlite:///./agriwatch.db
# DATABASE_URL=postgresql://user:password@localhost:5432/agriwatch

# Security
SECRET_KEY=change-this-to-a-random-secret-in-production

# Raspberry Pi
PI_STREAM_URL=http://raspberrypi.local:8080/stream
PI_HOST=raspberrypi.local

# Alert thresholds
PH_MIN=5.5
PH_MAX=7.5
MOISTURE_MIN=40.0
MOISTURE_MAX=80.0
HUMIDITY_MIN=30.0
HUMIDITY_MAX=90.0
TEMP_MIN=15.0
TEMP_MAX=35.0
